{
  "name": "r3f-mcp-basic",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently --names \"app,mcp\" -c \"cyan,green\" --kill-others-on-fail \"pnpm dev:app\" \"pnpm dev:mcp\"",
    "dev:app": "vite",
    "dev:mcp": "tsx watch ../../packages/server/src/index.ts --port 3333",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/drei": "^9.88.0",
    "@react-three/fiber": "^8.15.0",
    "r3f-mcp": "workspace:*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
